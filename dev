#!/bin/sh
set -e

SCRIPT_NAME="$(basename "$0")"
APP_SERVICE="app"

print_help() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [args]

Commands:
  up                 Build and start containers in detached mode
  down               Stop and remove containers
  restart            Restart containers (down then up)
  status             Show container status
  logs               Tail container logs
  shell              Open a shell in the app container
  artisan [args...]  Run php artisan inside the app container
  composer [args...] Run composer inside the app container
  npm [args...]      Run npm inside the app container
  init               Create .env if missing, generate APP_KEY, run migrations
  db-export [--local|--cloud] [file]
                     Export database to a .sql file
                     --local  (default) export from local Docker MySQL
                     --cloud  export from Cloud SQL via cloud-sql-proxy
                     Default filename: data/db-YYYY-MM-DD-{local|cloud}.sql
  db-import [--local|--cloud] <file>
                     Import a .sql file into local Docker MySQL or Cloud SQL
                     --local  (default) import into local Docker MySQL
                     --cloud  import into Cloud SQL via cloud-sql-proxy
  secrets-update    Push secrets from .env.production to GCP Secret Manager
  env-update         Push .env.production vars to Cloud Run (no rebuild needed)
                     Optionally pass --dry-run to preview the command
  env-get            Fetch live env vars from Cloud Run as KEY=VALUE pairs
                     Pass --yaml or --json for alternative formats
  migrate-cloud      Run pending migrations against Cloud SQL production DB
                     Uses cloud-sql-proxy + a one-off Docker container
  help               Show this help

Notes:
  - Uses docker compose when available, with docker-compose fallback.
  - The init command will start containers if they are not running.
EOF
}

compose_cmd() {
  if command -v docker >/dev/null 2>&1; then
    if docker compose version >/dev/null 2>&1; then
      echo "docker compose"
      return
    fi
  fi

  if command -v docker-compose >/dev/null 2>&1; then
    echo "docker-compose"
    return
  fi

  echo "Error: docker compose or docker-compose not found." >&2
  exit 1
}

ensure_env_file() {
  if [ ! -f .env ]; then
    if [ -f .env.example ]; then
      cp .env.example .env
      echo "Created .env from .env.example"
    else
      echo "Error: .env.example not found." >&2
      exit 1
    fi
  fi
}

is_app_running() {
  "$@" ps -q "$APP_SERVICE" 2>/dev/null | grep -q .
}

exec_app() {
  compose="$(compose_cmd)"
  $compose exec -T "$APP_SERVICE" "$@"
}

exec_app_tty() {
  compose="$(compose_cmd)"
  $compose exec "$APP_SERVICE" "$@"
}

run_up() {
  compose="$(compose_cmd)"
  ensure_env_file
  $compose up -d --build
}

run_down() {
  compose="$(compose_cmd)"
  $compose down
}

run_restart() {
  run_down
  run_up
}

run_status() {
  compose="$(compose_cmd)"
  $compose ps
}

run_logs() {
  compose="$(compose_cmd)"
  $compose logs -f --tail=200
}

run_shell() {
  exec_app_tty sh
}

run_artisan() {
  exec_app php artisan "$@"
}

run_composer() {
  exec_app composer "$@"
}

run_npm() {
  exec_app npm "$@"
}

# ── Cloud SQL config ─────────────────────────────────────────────────────────
CLOUD_SQL_INSTANCE="client-jussimatic:europe-north1:jussilog-db"
CLOUD_SQL_PROXY_PORT="3308"
CLOUD_SQL_DB="jussilog"
CLOUD_SQL_SOCKET_DIR="/tmp/cloudsql-dev"
# ─────────────────────────────────────────────────────────────────────────────

_read_env_var() {
  grep "^${1}=" "${2:-.env}" | cut -d= -f2- | tr -d '\r'
}

_start_cloud_proxy() {
  if ! command -v cloud-sql-proxy >/dev/null 2>&1; then
    echo "ERROR: cloud-sql-proxy not found." >&2
    echo "Install: curl -o cloud-sql-proxy https://storage.googleapis.com/cloud-sql-connectors/cloud-sql-proxy/v2.15.2/cloud-sql-proxy.linux.amd64 && chmod +x cloud-sql-proxy && sudo mv cloud-sql-proxy /usr/local/bin/" >&2
    exit 1
  fi
  PROXY_LOG="/tmp/cloud-sql-proxy-dev.log"
  echo "Starting Cloud SQL Proxy ($CLOUD_SQL_INSTANCE) on TCP port $CLOUD_SQL_PROXY_PORT ..."
  cloud-sql-proxy "$CLOUD_SQL_INSTANCE" --port "$CLOUD_SQL_PROXY_PORT" >"$PROXY_LOG" 2>&1 &
  PROXY_PID=$!
  TRIES=0
  while ! nc -z 127.0.0.1 "$CLOUD_SQL_PROXY_PORT" 2>/dev/null; do
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      echo "ERROR: Cloud SQL Proxy exited unexpectedly." >&2
      if [ -f "$PROXY_LOG" ]; then
        tail -n 20 "$PROXY_LOG" >&2 || true
      fi
      exit 1
    fi
    sleep 1
    TRIES=$((TRIES + 1))
    if [ $TRIES -ge 15 ]; then
      echo "ERROR: Cloud SQL Proxy did not start in time." >&2
      kill $PROXY_PID 2>/dev/null
      exit 1
    fi
  done
  echo "Proxy ready."
}

_stop_cloud_proxy() {
  if [ -n "${PROXY_PID:-}" ]; then
    kill $PROXY_PID 2>/dev/null || true
    PROXY_PID=
  fi
}

run_db_export() {
  TARGET="local"
  OUTFILE=""
  for arg in "$@"; do
    case "$arg" in
      --local) TARGET="local" ;;
      --cloud) TARGET="cloud" ;;
      *) OUTFILE="$arg" ;;
    esac
  done

  if [ "$TARGET" = "cloud" ]; then
    DB_USERNAME="$(_read_env_var DB_USERNAME .env.production)"
    DB_PASSWORD="$(_read_env_var DB_PASSWORD .env.production)"
    DB_DATABASE="$(_read_env_var DB_DATABASE .env.production)"
    DB_USERNAME="${DB_USERNAME:-root}"
    DB_DATABASE="${DB_DATABASE:-$CLOUD_SQL_DB}"
    OUTFILE="${OUTFILE:-data/db-$(date +%Y-%m-%d)-cloud.sql}"
    mkdir -p "$(dirname "$OUTFILE")"
    trap '_stop_cloud_proxy' EXIT INT TERM
    _start_cloud_proxy
    echo "Exporting Cloud SQL '$DB_DATABASE' to $OUTFILE ..."
    mysqldump \
      -h 127.0.0.1 -P "$CLOUD_SQL_PROXY_PORT" \
      -u "$DB_USERNAME" \
      -p"$DB_PASSWORD" \
      --ssl-mode=DISABLED \
      --get-server-public-key \
      --no-tablespaces \
      --single-transaction \
      --routines \
      --triggers \
      "$DB_DATABASE" > "$OUTFILE"
    _stop_cloud_proxy
    trap - EXIT INT TERM
  else
    compose="$(compose_cmd)"
    DB_DATABASE="$(_read_env_var DB_DATABASE)"
    DB_USERNAME="$(_read_env_var DB_USERNAME)"
    DB_PASSWORD="$(_read_env_var DB_PASSWORD)"
    DB_PORT="$(_read_env_var DB_PORT)"
    OUTFILE="${OUTFILE:-data/db-$(date +%Y-%m-%d)-local.sql}"
    mkdir -p "$(dirname "$OUTFILE")"
    echo "Exporting local Docker MySQL '$DB_DATABASE' to $OUTFILE ..."
    $compose exec -T mysql mysqldump \
      -h 127.0.0.1 \
      -P "${DB_PORT:-3306}" \
      -u "$DB_USERNAME" \
      -p"$DB_PASSWORD" \
      --ssl-mode=DISABLED \
      --get-server-public-key \
      --no-tablespaces \
      --single-transaction \
      --routines \
      --triggers \
      "$DB_DATABASE" 2>/dev/null > "$OUTFILE"
  fi
  echo "Export done: $OUTFILE"
}

run_db_import() {
  TARGET="local"
  INFILE=""
  for arg in "$@"; do
    case "$arg" in
      --local) TARGET="local" ;;
      --cloud) TARGET="cloud" ;;
      *) INFILE="$arg" ;;
    esac
  done

  if [ -z "$INFILE" ]; then
    echo "Usage: ./dev db-import [--local|--cloud] <file.sql>" >&2
    exit 1
  fi
  if [ ! -f "$INFILE" ]; then
    echo "Error: file not found: $INFILE" >&2
    exit 1
  fi

  if [ "$TARGET" = "cloud" ]; then
    DB_USERNAME="$(_read_env_var DB_USERNAME .env.production)"
    DB_PASSWORD="$(_read_env_var DB_PASSWORD .env.production)"
    DB_DATABASE="$(_read_env_var DB_DATABASE .env.production)"
    DB_USERNAME="${DB_USERNAME:-root}"
    DB_DATABASE="${DB_DATABASE:-$CLOUD_SQL_DB}"
    trap '_stop_cloud_proxy' EXIT INT TERM
    _start_cloud_proxy
    echo "Importing '$INFILE' into Cloud SQL '$DB_DATABASE' ..."
    mysql \
      -h 127.0.0.1 -P "$CLOUD_SQL_PROXY_PORT" \
      -u "$DB_USERNAME" \
      -p"$DB_PASSWORD" \
      --ssl-mode=DISABLED \
      --get-server-public-key \
      "$DB_DATABASE" < "$INFILE"
    _stop_cloud_proxy
    trap - EXIT INT TERM
  else
    compose="$(compose_cmd)"
    DB_DATABASE="$(_read_env_var DB_DATABASE)"
    DB_USERNAME="$(_read_env_var DB_USERNAME)"
    DB_PASSWORD="$(_read_env_var DB_PASSWORD)"
    DB_PORT="$(_read_env_var DB_PORT)"
    echo "Importing '$INFILE' into local Docker MySQL '$DB_DATABASE' ..."
    $compose exec -T mysql mysql \
      -h 127.0.0.1 \
      -P "${DB_PORT:-3306}" \
      -u "$DB_USERNAME" \
      -p"$DB_PASSWORD" \
      --ssl-mode=DISABLED \
      "$DB_DATABASE" < "$INFILE"
  fi
  echo "Import done."
}

run_secrets_update() {
  if [ ! -f scripts/update-secret-manager.sh ]; then
    echo "Error: scripts/update-secret-manager.sh not found." >&2
    exit 1
  fi
  bash scripts/update-secret-manager.sh "$@"
}

run_env_update() {
  if [ ! -f scripts/set-cloud-run-env.sh ]; then
    echo "Error: scripts/set-cloud-run-env.sh not found." >&2
    exit 1
  fi
  sh scripts/set-cloud-run-env.sh "$@"
}

run_env_get() {
  if [ ! -f scripts/get-cloud-run-env.sh ]; then
    echo "Error: scripts/get-cloud-run-env.sh not found." >&2
    exit 1
  fi
  sh scripts/get-cloud-run-env.sh "$@"
}

run_migrate_cloud() {
  DB_USERNAME="$(_read_env_var DB_USERNAME .env.production)"
  DB_PASSWORD="$(_read_env_var DB_PASSWORD .env.production)"
  DB_DATABASE="$(_read_env_var DB_DATABASE .env.production)"
  DB_USERNAME="${DB_USERNAME:-root}"
  DB_DATABASE="${DB_DATABASE:-$CLOUD_SQL_DB}"
  trap '_stop_cloud_proxy' EXIT INT TERM
  _start_cloud_proxy
  echo "Running migrations against Cloud SQL '$DB_DATABASE' ..."
  DB_CONNECTION=mysql \
  DB_HOST=127.0.0.1 \
  DB_SOCKET= \
  DB_PORT="$CLOUD_SQL_PROXY_PORT" \
  DB_DATABASE="$DB_DATABASE" \
  DB_USERNAME="$DB_USERNAME" \
  DB_PASSWORD="$DB_PASSWORD" \
    php artisan migrate --force --no-interaction
  _stop_cloud_proxy
  trap - EXIT INT TERM
}

run_init() {
  compose="$(compose_cmd)"
  ensure_env_file

  if ! is_app_running $compose; then
    $compose up -d --build
  fi

  echo "Generating APP_KEY..."
  $compose exec -T "$APP_SERVICE" php artisan key:generate --force

  echo "Running migrations..."
  $compose exec -T "$APP_SERVICE" php artisan migrate --force --no-interaction
}

case "$1" in
  up)
    shift
    run_up
    ;;
  down)
    shift
    run_down
    ;;
  restart)
    shift
    run_restart
    ;;
  status)
    shift
    run_status
    ;;
  logs)
    shift
    run_logs
    ;;
  shell)
    shift
    run_shell
    ;;
  artisan)
    shift
    run_artisan "$@"
    ;;
  composer)
    shift
    run_composer "$@"
    ;;
  npm)
    shift
    run_npm "$@"
    ;;
  db-export)
    shift
    run_db_export "$@"
    ;;
  db-import)
    shift
    run_db_import "$@"
    ;;
  secrets-update)
    shift
    run_secrets_update "$@"
    ;;
  env-update)
    shift
    run_env_update "$@"
    ;;
  env-get)
    shift
    run_env_get "$@"
    ;;
  migrate-cloud)
    shift
    run_migrate_cloud
    ;;
  init)
    shift
    run_init
    ;;
  help|--help|-h|"")
    print_help
    ;;
  *)
    echo "Unknown command: $1" >&2
    print_help
    exit 1
    ;;
esac
