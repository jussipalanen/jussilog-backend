# Production environment variables for Google Cloud Run
# Copy this file to .env.production and fill in real values.
# .env.production is gitignored — never commit secrets.
#
# Apply to Cloud Run (without redeployment):
#   ./dev env-update
# Or directly:
#   scripts/set-cloud-run-env.sh

# -- Application --
APP_NAME=JussiLog
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REPLACE_WITH_YOUR_APP_KEY
APP_URL=https://REPLACE_WITH_YOUR_CLOUD_RUN_URL
FRONTEND_URL=https://REPLACE_WITH_YOUR_FRONTEND_URL

# -- Database (Cloud SQL via Unix socket) --
# Cloud SQL instance: client-jussimatic:europe-north1:jussilog-db
DB_CONNECTION=mysql
DB_HOST=/cloudsql/client-jussimatic:europe-north1:jussilog-db
DB_PORT=3306
DB_DATABASE=jussilog
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# -- Cache & Session --
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# -- Logging --
LOG_CHANNEL=stderr
LOG_LEVEL=error

# -- Mail --
MAIL_ENABLED=true
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_BREVO_USERNAME
MAIL_PASSWORD=REPLACE_WITH_BREVO_API_KEY
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@REPLACE_WITH_YOUR_DOMAIN
MAIL_FROM_NAME=JussiLog

# -- File Storage --
FILESYSTEM_DISK=gcs
GCS_ACCESS_KEY_ID=REPLACE_WITH_GCS_HMAC_KEY
GCS_SECRET_ACCESS_KEY=REPLACE_WITH_GCS_HMAC_SECRET
GCS_DEFAULT_REGION=us
GCS_BUCKET=REPLACE_WITH_BUCKET_NAME
GCS_URL=
GCS_ENDPOINT=https://storage.googleapis.com
GCS_USE_PATH_STYLE_ENDPOINT=false

# -- Scribe API Docs --
SCRIBE_BASE_URL=https://REPLACE_WITH_YOUR_CLOUD_RUN_URL
SCRIBE_TRY_IT_OUT_BASE_URL=https://REPLACE_WITH_YOUR_CLOUD_RUN_URL
SCRIBE_AUTH_KEY=REPLACE_WITH_SCRIBE_AUTH_KEY

# -- Secret endpoint (for test purposes) --
UPDATE_USER_ROLE_SECRET=REPLACE_WITH_RANDOM_SECRET
